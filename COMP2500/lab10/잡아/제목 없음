//----------------------MovieStore.java----------------------

package academy.pocu.comp2500.lab10;

import java.util.ArrayList;

import academy.pocu.comp2500.lab10.pocuflix.Movie;
import academy.pocu.comp2500.lab10.pocuflix.NotFoundResult;
import academy.pocu.comp2500.lab10.pocuflix.OkResult;
import academy.pocu.comp2500.lab10.pocuflix.ResultBase;

public class MovieStore implements IRequestHandler {

    private ArrayList<Movie> movies;

    public MovieStore() {
        this.movies = new ArrayList<>();
    }

    public ArrayList<Movie> getMovies() {
        return movies;
    }

    public void add(Movie movie) {
        if (movie != null) {
            movies.add(movie);
        }
    }

    public boolean remove(int index) {
        if (index >= movies.size() || index < 0) {
            return false;
        }
        movies.remove(index);
        return true;
    }

    public ResultBase handle(Request request) {
        for (Movie movie : movies) {
            if (request.getTitle().equals(movie.getTitle())) {
                return new OkResult(movie);
            }
        }
        return new NotFoundResult();
    }
}


//----------------------AuthorizationMiddleware.java----------------------

package academy.pocu.comp2500.lab10;

import java.util.HashSet;

import academy.pocu.comp2500.lab10.pocuflix.ResultBase;
import academy.pocu.comp2500.lab10.pocuflix.User;

public class AuthorizationMiddleware implements IRequestHandler {
    private IRequestHandler store;
    private HashSet<User> users;

    public AuthorizationMiddleware(IRequestHandler store, HashSet<User> users) {
        this.store = store;
        this.users = users;
    }

    public ResultBase handle(Request request) {
        for (User user : users) {
            if (user.equals(request.getUser())) {
                return store.handle(request);
            }
        }
        return new UnauthorizedResult();
    }

}


