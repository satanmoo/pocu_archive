//----------------------CacheMiddleware.java----------------------

package academy.pocu.comp2500.lab10;

import java.util.HashMap;

import academy.pocu.comp2500.lab10.pocuflix.OkResult;
import academy.pocu.comp2500.lab10.pocuflix.ResultBase;

public class CacheMiddleware implements IRequestHandler {
    private IRequestHandler store;
    private int numRequests;
    private HashMap<Request, Integer> dict;

    public CacheMiddleware(IRequestHandler store, int numRequests) {
        this.store = store;
        this.numRequests = numRequests;
        this.dict = new HashMap<>();
    }

    public ResultBase handle(Request request) {
        // 이미 cache 남아 있는 경우 : caching이 최우선 작업
        if (dict.containsKey(request) && this.dict.get(request) > 1) {
            this.dict.put(request, this.dict.get(request) - 1);

            return new CachedResult(this.dict.get(request));
        }

        // 새로운 request or numRequest 갱신
        if (this.store.handle(request) instanceof OkResult) {
            this.dict.put(request, this.numRequests);
        }

        return this.store.handle(request);
    }
}


