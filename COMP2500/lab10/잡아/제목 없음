//----------------------MaintenanceMiddleware.java----------------------

package academy.pocu.comp2500.lab10;

import java.time.OffsetDateTime;
import java.time.ZoneOffset;

import academy.pocu.comp2500.lab10.pocuflix.ResultBase;

public class MaintenanceMiddleware implements IRequestHandler {
    private IRequestHandler store;
    private OffsetDateTime time;
    private OffsetDateTime now;

    public MaintenanceMiddleware(IRequestHandler store, OffsetDateTime time) {
        this.store = store;
        this.time = time; // 이 개체 호출되고 time 뒤 1시간동안 점검!
    }

    public ResultBase handle(Request request) {
        this.now = OffsetDateTime.now(ZoneOffset.UTC);
        if (this.now.compareTo(time) > 0 && this.now.compareTo(this.time.plusHours(1)) < 0) {
            return new ServiceUnavailableResult(this.time, this.time.plusHours(1));
        }
        return store.handle(request);
    }
}


