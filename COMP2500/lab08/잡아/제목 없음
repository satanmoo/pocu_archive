//----------------------SmartDevice.java----------------------

package academy.pocu.comp2500.lab8;

public abstract class SmartDevice {

    protected int tick;
    protected int lastUpdatedTick;
    protected boolean isOn;

    protected SmartDevice() {
        this.tick = 0;
        this.lastUpdatedTick = 0;
        this.isOn = false;
    }

    public boolean isOn() {
        return this.isOn;
    }

    public void setIsOn(boolean isOn) {
        this.lastUpdatedTick = this.tick;
        this.isOn = isOn;
    }

    public void onTick() {
        this.tick += 1;
    }

    public int getTick() {
        return this.tick;
    }

    public int getTicksSinceLastUpdate() {
        return this.tick - this.lastUpdatedTick;
    }

    public abstract void work(Planter planter);

}


//----------------------Sprinkler.java----------------------

package academy.pocu.comp2500.lab8;

import java.util.ArrayList;

public class Sprinkler extends SmartDevice implements ISprayable {
    private ArrayList<Schedule> schedules;
    private Schedule currentSchedule;
    private int currentScheduleIndex;

    public Sprinkler() {
        this.schedules = new ArrayList<>();
        this.currentSchedule = null;
        this.currentScheduleIndex = 0;
    }

    public void addSchedule(Schedule schedule) {
        if (schedule != null && this.tick == 0) {
            schedules.add(schedule);
        }
    }

    public ArrayList<Schedule> getSchedules() {
        return this.schedules;
    }

    @Override
    public void onTick() {
        this.tick += 1;

        if (this.currentSchedule != null) {

            // 잘 작동하던 스케줄 종료
            if (this.isOn()
                    && (this.currentSchedule.getOffCount() == this.getTicksSinceLastUpdate())) {
                this.currentScheduleIndex += 1;
                this.currentSchedule = null;
                this.setIsOn(false);
                return;

                // 안돌아가던 스케줄 종료
            } else if (!this.isOn() &&
                    (this.currentSchedule.getOnCount() + this.currentSchedule.getOffCount() == this.tick)) {
                this.currentScheduleIndex += 1;
                this.currentSchedule = null;
                return;

            }
        } 
        
        // 스케줄 없어서 새로 할당받아야 함
        if (this.currentSchedule == null) {
            for (int i = currentScheduleIndex; i < schedules.size(); ++i) {

                Schedule schedule = schedules.get(i);
                this.currentScheduleIndex = i;

                // 0시작은 유효하지 않은 경우라 무시함
                if (schedule.getOnCount() == 0) {
                    continue;
                }

                // 못쓰는 스케줄이지만 끝까지 훑어야 함
                if (schedule.getOnCount() < this.tick &&
                        (this.tick <= schedule.getOnCount() + schedule.getOffCount())) {
                    this.currentSchedule = schedule;
                    break;
                }
                
                // 미래에 쓸 스케줄
                if (schedule.getOnCount() > this.tick) {
                    break;
                }

                // 작동하는 스케줄 찾음 !
                if (schedule.getOnCount() == this.tick) {
                    this.currentSchedule = schedule;
                    this.setIsOn(true);
                    break;
                }
            }
        }

    }

    @Override
    public void spray(Planter planter) {
        planter.setWaterAmountChange(
                planter.getWaterAmountChange() + 15);
    }

    @Override
    public void work(Planter planter) {
        if (this.isOn()) {
            spray(planter);
        }
    }
}


//----------------------Drainer.java----------------------

package academy.pocu.comp2500.lab8;

public class Drainer extends SmartDevice implements IDrainable, IWaterDetectable {
    private int drainThreshold;

    public Drainer(int drainThreshold) {
        this.drainThreshold = drainThreshold;
    }

    public int getDrainThreshold() {
        return drainThreshold;
    }

    @Override
    public void drain(Planter planter) {
        planter.setWaterAmountChange(planter.getWaterAmountChange() - 7);
    }

    @Override
    public void detect(final int waterLevel) {
        if (waterLevel >= this.drainThreshold && this.isOn() == false) {
            this.setIsOn(true);
        } else if (waterLevel < this.drainThreshold && this.isOn() == true) {
            this.setIsOn(false);
        }
    }

    @Override
    public void work(Planter planter) {
        detect(planter.getWaterAmount());
        if (this.isOn()) {
            drain(planter);
        }
    }
}


//----------------------Planter.java----------------------

package academy.pocu.comp2500.lab8;

import java.util.ArrayList;

public class Planter {
    private int waterAmount;
    private int waterAmountChange;
    private ArrayList<SmartDevice> smartDevices;

    public Planter(int waterAmount) {
        this.waterAmount = waterAmount;
        this.waterAmountChange = 0;
        this.smartDevices = new ArrayList<>();
    }

    public int getWaterAmount() {
        return waterAmount;
    }

    public int getWaterAmountChange() {
        return waterAmountChange;
    }

    public void setWaterAmountChange(int waterAmountChange) {
        this.waterAmountChange = waterAmountChange;
    }

    public void setWaterAmount(int waterAmountInLiter) {
        this.waterAmount = Math.max(waterAmountInLiter, 0);
    }

    public void installSmartDevice(SmartDevice smartDevice) {
        smartDevices.add(smartDevice);
    }

    public void tick() {
        for (SmartDevice device : smartDevices) {
            device.onTick();
            device.work(this);
        }
        this.waterAmount = Math.max(
                waterAmount + waterAmountChange - 2, 0);
        this.waterAmountChange = 0;
        // drain과 동시에 동시에 작동함, 직접 값을 바꾸면 sprinkler, drain
        // 호출 순서에 따라 결과 달라지므로, delta값을 변경하여 tick 마무리될 때
        // 일괄 적용
    }

}